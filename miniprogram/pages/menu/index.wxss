.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部购物车图标 */
.top-cart {
  position: fixed;
  top: 20rpx;
  right: 20rpx;
  z-index: 100;
  width: 80rpx;
  height: 80rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.cart-icon {
  font-size: 36rpx;
}

.cart-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 32rpx;
  height: 32rpx;
  background: #ff4d4f;
  color: white;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

/* 分类栏 */
.category-scroll {
  white-space: nowrap;
  background: white;
  padding: 24rpx 0 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.category-item.active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.category-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #666;
}

.category-item.active .category-name {
  color: white;
}

/* 菜品列表 */
.dish-list {
  height: calc(100vh - 200rpx);
  padding: 20rpx;
}

.dish-card {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  transition: all 0.3s;
}

.dish-card.in-cart {
  border: 2rpx solid #10b981;
  background: #f0fdf4;
}

.dish-image {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.dish-card.in-cart .dish-image {
  background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);
}

.emoji-text {
  font-size: 60rpx;
}

.in-cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background: #10b981;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(16, 185, 129, 0.4);
}

.dish-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.dish-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.dish-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.difficulty-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.difficulty-easy {
  background: #dcfce7;
  color: #16a34a;
}

.difficulty-medium {
  background: #fef3c7;
  color: #d97706;
}

.difficulty-hard {
  background: #fee2e2;
  color: #dc2626;
}

.dish-sales {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.sales-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.sales-text {
  font-size: 24rpx;
  color: #999;
}

.dish-actions {
  display: flex;
  gap: 16rpx;
  margin-top: auto;
}

.action-btn {
  flex: 1;
  padding: 16rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  transition: all 0.2s;
}

.action-btn.primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
  box-shadow: 0 2rpx 8rpx rgba(99, 102, 241, 0.3);
}

.action-btn.added {
  background: #dcfce7;
  color: #16a34a;
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.action-btn:active {
  transform: scale(0.95);
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  color: white;
  font-size: 28rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.detail-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.ingredients-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.ingredient-item {
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.step-item {
  display: flex;
  gap: 16rpx;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  background: #6366f1;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.step-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
}

.modal-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
}

.modal-btn.secondary {
  background: #f5f5f5;
  color: #666;
}
