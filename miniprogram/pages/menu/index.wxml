<view class="container">
  <!-- 顶部购物车图标 -->
  <view class="top-cart" bindtap="goToCart">
    <view class="cart-icon">🛒</view>
    <view wx:if="{{cartCount > 0}}" class="cart-badge">{{cartCount}}</view>
  </view>

  <!-- 分类栏 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="*this"
        class="category-item {{activeCategory === item ? 'active' : ''}}"
        bindtap="selectCategory"
        data-category="{{item}}"
      >
        <text class="category-emoji">{{categoryEmojis[item]}}</text>
        <text class="category-name">{{item}}</text>
      </view>
    </view>
  </scroll-view>
  
  <!-- 菜品列表 -->
  <scroll-view class="dish-list" scroll-y>
    <view wx:for="{{dishes}}" wx:key="id" class="dish-card {{cartIds.includes(item.id) ? 'in-cart' : ''}}">
      <view class="dish-image">
        <text class="emoji-text">{{categoryEmojis[item.category]}}</text>
        <view wx:if="{{cartIds.includes(item.id)}}" class="in-cart-badge">✓ 已添加</view>
      </view>
      <view class="dish-info">
        <view class="dish-header">
          <text class="dish-name">{{item.name}}</text>
          <text class="difficulty-tag difficulty-{{item.difficulty}}">
            {{getDifficultyLabel(item.difficulty)}}
          </text>
        </view>
        <view class="dish-sales">
          <text class="sales-icon">👁️</text>
          <text class="sales-text">{{item.sales}} 人点过</text>
        </view>
        <view class="dish-actions">
          <view class="action-btn secondary" bindtap="showDishDetail" data-id="{{item.id}}">
            <text>查看</text>
          </view>
          <view class="action-btn {{cartIds.includes(item.id) ? 'added' : 'primary'}}" bindtap="addToCartDirect" data-id="{{item.id}}">
            <text>{{cartIds.includes(item.id) ? '已添加' : '添加'}}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
  
  <!-- 详情弹窗 -->
  <view wx:if="{{showModal}}" class="modal-overlay" bindtap="closeModal">
    <view class="modal-content" catchtap="">
      <view class="modal-header">
        <text class="modal-title">{{selectedDish.name}}</text>
        <view class="close-btn" bindtap="closeModal">
          <text>✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="detail-section">
          <text class="section-title">🥬 食材</text>
          <view class="ingredients-list">
            <text wx:for="{{selectedDish.ingredients}}" wx:for-item="ingredient" wx:key="*this" class="ingredient-item">
              • {{ingredient}}
            </text>
          </view>
        </view>
        <view class="detail-section">
          <text class="section-title">👨‍🍳 做法步骤</text>
          <view class="steps-list">
            <view wx:for="{{selectedDish.steps}}" wx:for-item="step" wx:for-index="index" wx:key="index" class="step-item">
              <text class="step-number">{{index + 1}}</text>
              <text class="step-text">{{step}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <view class="modal-btn secondary" bindtap="closeModal">
          <text>关闭</text>
        </view>
        <view class="modal-btn primary" bindtap="addToCart">
          <text>添加到购物车</text>
        </view>
      </view>
    </view>
  </view>
</view>
