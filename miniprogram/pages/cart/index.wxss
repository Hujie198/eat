.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: white;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.clear-btn {
  padding: 12rpx 24rpx;
  background: #fee2e2;
  color: #dc2626;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.clear-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.cart-list {
  height: calc(100vh - 120rpx);
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.item-image {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.emoji-text {
  font-size: 48rpx;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
}

.item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.difficulty-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.difficulty-easy {
  background: #dcfce7;
  color: #16a34a;
}

.difficulty-medium {
  background: #fef3c7;
  color: #d97706;
}

.difficulty-hard {
  background: #fee2e2;
  color: #dc2626;
}

.category-text {
  font-size: 22rpx;
  color: #999;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  text-align: center;
  transition: all 0.2s;
}

.action-btn.view {
  background: #f5f5f5;
  color: #666;
}

.action-btn.remove {
  background: #fee2e2;
  color: #dc2626;
}

.action-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.go-menu-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(99, 102, 241, 0.3);
}

.go-menu-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}
