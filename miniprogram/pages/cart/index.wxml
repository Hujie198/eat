<view class="container">
  <view class="header">
    <text class="header-title">🛒 干饭清单</text>
    <view class="clear-btn" bindtap="clearCart" wx:if="{{cartCount > 0}}">
      <text>清空</text>
    </view>
  </view>
  
  <scroll-view class="cart-list" scroll-y wx:if="{{cartDishes.length > 0}}">
    <view wx:for="{{cartDishes}}" wx:key="id" class="cart-item">
      <view class="item-image">
        <text class="emoji-text">{{categoryEmojis[item.category]}}</text>
      </view>
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <view class="item-meta">
          <text class="difficulty-tag difficulty-{{item.difficulty}}">
            {{getDifficultyLabel(item.difficulty)}}
          </text>
          <text class="category-text">{{item.category}}</text>
        </view>
      </view>
      <view class="item-actions">
        <view class="action-btn view" bindtap="showDishDetail" data-id="{{item.id}}">
          <text>查看</text>
        </view>
        <view class="action-btn remove" bindtap="removeFromCart" data-id="{{item.id}}">
          <text>删除</text>
        </view>
      </view>
    </view>
  </scroll-view>
  
  <view class="empty-state" wx:else>
    <text class="empty-icon">🍽️</text>
    <text class="empty-text">购物车是空的</text>
    <text class="empty-hint">快去菜单看看有什么好吃的</text>
    <view class="go-menu-btn" bindtap="goToMenu">
      <text>去点菜</text>
    </view>
  </view>
</view>
