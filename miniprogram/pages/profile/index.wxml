<view class="container">
  <view class="header">
    <view class="user-info">
      <view class="avatar">
      <text>👤</text>
      </view>
      <text class="username">我的</text>
    </view>
  </view>
  
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{totalOrders}}</text>
      <text class="stat-label">总点菜次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">{{historyCount}}</text>
      <text class="stat-label">吃过的菜</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-value">8</text>
      <text class="stat-label">菜系探索</text>
    </view>
  </view>
  
  <view class="share-card">
    <text class="card-title">🔗 家庭共享</text>
    <view class="share-buttons">
      <view class="share-btn primary-btn" bindtap="showShareModal">
        <text class="btn-icon">📤</text>
        <text class="btn-text">分享我的</text>
      </view>
      <view class="share-btn" bindtap="showJoinModal">
        <text class="btn-icon">📥</text>
        <text class="btn-text">加入他人</text>
      </view>
    </view>
    <view class="share-tip">
      <text>💡 家人使用同一购物车ID，共享实时点菜数据</text>
    </view>
  </view>
  
  <view class="history-card">
    <text class="card-title">📜 点菜历史</text>
    <scroll-view class="history-list" scroll-y wx:if="{{historyDishes.length > 0}}">
      <view wx:for="{{historyDishes}}" wx:key="id" class="history-item" bindtap="showDishDetail" data-id="{{item.id}}">
        <view class="item-image">
          <text class="emoji-text">{{categoryEmojis[item.category]}}</text>
        </view>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <view class="item-meta">
            <text class="difficulty-tag difficulty-{{item.difficulty}}">
              {{getDifficultyLabel(item.difficulty)}}
            </text>
            <text class="category-text">{{item.category}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view class="empty-history" wx:else>
      <text class="empty-icon">📝</text>
      <text class="empty-text">暂无点菜记录</text>
    </view>
  </view>
  
  <!-- 分享购物车弹窗 -->
  <view class="modal-overlay" wx:if="{{showShareModal}}" bindtap="closeShareModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">📤 分享购物车</text>
      <view class="share-info">
        <text class="info-label">你的购物车ID：</text>
        <view class="share-code-box">
          <text class="share-code">{{cartId}}</text>
        </view>
        <view class="copy-btn" bindtap="copyCartId">
          <text>{{copied ? '✓ 已复制' : '复制ID'}}</text>
        </view>
        <view class="share-instructions">
          <text class="instruction-title">📝 使用方法：</text>
          <text class="instruction-item">1. 复制购物车ID</text>
          <text class="instruction-item">2. 分享给家人</text>
          <text class="instruction-item">3. 家人点击「加入他人」并粘贴此ID</text>
          <text class="instruction-item">4. 实时共享所有点菜数据</text>
        </view>
        <view class="share-instructions alt">
          <text class="instruction-title">⚠️ 注意事项：</text>
          <text class="instruction-item">• 需要先配置微信云开发</text>
          <text class="instruction-item">• 启用后支持多人实时同步</text>
          <text class="instruction-item">• 未启用也可本地单独使用</text>
        </view>
      </view>
      <view class="modal-btn primary" bindtap="closeShareModal">
        <text>知道了</text>
      </view>
    </view>
  </view>
  
  <!-- 加入共享购物车弹窗 -->
  <view class="modal-overlay" wx:if="{{showJoinModal}}" bindtap="closeJoinModal">
    <view class="modal-content" catchtap="">
      <text class="modal-title">📥 加入共享购物车</text>
      <view class="share-info">
        <text class="info-label">输入家人分享的购物车ID：</text>
        <input class="input-field" type="text" value="{{inputCartId}}" bindinput="onInputCartId" placeholder="cart_xxxx" />
        <view class="share-instructions alt">
          <text class="instruction-title">📝 使用说明：</text>
          <text class="instruction-item">• ID格式：cart_数字</text>
          <text class="instruction-item">• 加入后将替换你的购物车</text>
          <text class="instruction-item">• 与家人实时共享同一份购物车</text>
        </view>
      </view>
      <view class="modal-actions">
        <view class="modal-btn secondary" bindtap="closeJoinModal">
          <text>取消</text>
        </view>
        <view class="modal-btn primary" bindtap="joinSharedCart">
            <text>确认加入</text>
        </view>
      </view>
    </view>
  </view>
</view>
