.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.header {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  padding: 40rpx 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar text {
  font-size: 48rpx;
}

.username {
  font-size: 36rpx;
  font-weight: 600;
  color: white;
}

.stats-card {
  display: flex;
  align-items: center;
  background: white;
  margin: -40rpx 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #f0f0f0;
}

.share-card {
  background: white;
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.share-buttons {
  display: flex;
  gap: 20rpx;
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 16rpx;
  transition: all 0.2s;
}

.share-btn.primary-btn {
  background: linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%);
}

.share-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.btn-text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.share-tip {
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fef3c7;
  border-radius: 12rpx;
}

.share-tip text {
  font-size: 22rpx;
  color: #92400e;
  line-height: 1.6;
}

.history-card {
  background: white;
  margin: 0 20rpx;
  border-radius: 20rpx;
  padding: 24rpx;
}

.history-list {
  max-height: 600rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: #f9fafb;
  border-radius: 12rpx;
}

.item-image {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fed7aa 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.emoji-text {
  font-size: 36rpx;
}

.item-info {
  flex: 1;
  margin-left: 16rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.difficulty-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.difficulty-easy {
  background: #dcfce7;
  color: #16a34a;
}

.difficulty-medium {
  background: #fef3c7;
  color: #d97706;
}

.difficulty-hard {
  background: #fee2e2;
  color: #dc2626;
}

.category-text {
  font-size: 22rpx;
  color: #999;
}

.empty-history {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
}

.share-info {
  text-align: left;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 12rpx;
}

.share-code-box {
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.share-code {
  font-size: 24rpx;
  color: #666;
  word-break: break-all;
  font-family: monospace;
}

.input-field {
  width: 100%;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.copy-btn {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.copy-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.share-instructions {
  background: #fef3c7;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.share-instructions.alt {
  background: #e0f2fe;
}

.instruction-title {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  line-height: 1.8;
  display: block;
  margin-bottom: 8rpx;
}

.instruction-item {
  font-size: 24rpx;
  color: #555;
  line-height: 1.8;
  display: block;
}

.modal-btn {
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: white;
}

.modal-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

.modal-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
}

.modal-actions .modal-btn {
  flex: 1;
}
